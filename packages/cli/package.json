  },
  "files": [
    "bin/",
    "dist/",
    "assets/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
