{
  "name": "api",
  "version": "0.12.1",
  "homepage": "https://betterdb.com",
  "private": true,
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --testRegex='.e2e-spec.ts$'",
    "test:integration:api": "jest --testRegex='api-.*.e2e-spec.ts'",
    "test:integration:health": "jest test/api-health.e2e-spec.ts",
    "test:integration:metrics": "jest test/api-metrics.e2e-spec.ts",
    "test:integration:prometheus": "jest test/api-prometheus.e2e-spec.ts",
    "test:integration:settings": "jest test/api-settings.e2e-spec.ts",
    "test:integration:audit": "jest test/api-audit.e2e-spec.ts",
    "test:integration:client-analytics": "jest test/api-client-analytics.e2e-spec.ts",
    "test:integration:full": "jest test/api-full-flow.e2e-spec.ts",
    "test:integration:redis": "TEST_DB_PORT=6392 jest test/database-compatibility.e2e-spec.ts",
    "test:integration:valkey": "TEST_DB_PORT=6390 jest --testRegex='.e2e-spec.ts$'",
    "test:cluster": "jest test/api-cluster.e2e-spec.ts",
    "test:migration-topology": "RUN_TOPOLOGY_TESTS=true jest test/migration-topology.e2e-spec.ts",
    "test:cluster:unit": "jest src/cluster/*.spec.ts",
    "test:integration:cluster": "TEST_DB_HOST=localhost TEST_DB_PORT=7001 jest test/api-cluster.e2e-spec.ts",
    "test:unit:parsers": "jest src/database/parsers/*.spec.ts",
    "ai:index-docs": "ts-node -r tsconfig-paths/register scripts/index-valkey-docs.ts",
    "docs:download": "EMBED=false ts-node -r tsconfig-paths/register scripts/index-docs.ts",
    "docs:index": "ts-node -r tsconfig-paths/register scripts/index-docs.ts",
    "docs:index:valkey": "SOURCE=valkey ts-node -r tsconfig-paths/register scripts/index-docs.ts",
    "docs:index:redis": "SOURCE=redis ts-node -r tsconfig-paths/register scripts/index-docs.ts",
    "docs:clean": "rm -rf data/docs data/chunks data/vector-store",
    "seed:demo": "ts-node -r tsconfig-paths/register scripts/seed-demo-data.ts"
  },
  "dependencies": {
    "@betterdb/shared": "workspace:*",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@lancedb/lancedb": "^0.23.0",
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.35",
    "@langchain/ollama": "^1.2.6",
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "apache-arrow": "^21.1.0",
    "better-sqlite3": "^12.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.4",
    "hnswlib-node": "^3.0.0",
    "iovalkey": "^0.3.3",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.36",
    "lru-cache": "^11.2.7",
    "ollama": "^0.6.3",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "semver": "^7.7.4",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}