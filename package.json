{
  "name": "betterdb-monitor",
  "version": "0.9.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "proprietary/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"web,api\" -c \"green,blue\" \"cd apps/web && pnpm dev\" \"cd apps/api && pnpm dev\"",
    "dev:turbo": "turbo dev",
    "dev:api": "turbo dev --filter=api",
    "dev:web": "turbo dev --filter=web",
    "dev:entitlement": "cd proprietary/entitlement && pnpm dev",
    "build": "turbo build",
    "build:api": "turbo build --filter=api",
    "build:web": "turbo build --filter=web",
    "build:entitlement": "cd proprietary/entitlement && pnpm build",
    "start:prod": "NODE_ENV=production node apps/api/dist/apps/api/src/main.js",
    "start:entitlement": "cd proprietary/entitlement && pnpm start",
    "docker:build": "docker build --build-arg APP_VERSION=$(node -p 'require(`./package.json`).version') -t betterdb/monitor:latest .",
    "docker:build:no-ai": "docker build --build-arg APP_VERSION=$(node -p 'require(`./package.json`).version') -f Dockerfile.prod -t betterdb/monitor:no-ai .",
    "docker:push": "docker push betterdb/monitor:latest",
    "docker:push:no-ai": "docker push betterdb/monitor:no-ai",
    "docker:publish": "docker buildx build --build-arg APP_VERSION=$(node -p 'require(`./package.json`).version') --platform linux/amd64,linux/arm64 -t betterdb/monitor:latest --push .",
    "docker:publish:no-ai": "docker buildx build --build-arg APP_VERSION=$(node -p 'require(`./package.json`).version') -f Dockerfile.prod --platform linux/amd64,linux/arm64 -t betterdb/monitor:no-ai --push .",
    "docker:run": "docker run -p 3001:3001 --env-file .env betterdb/monitor",
    "docker:dev": "docker compose up -d",
    "docker:dev:down": "docker compose down",
    "docs:download": "pnpm --filter api docs:download",
    "docs:index": "pnpm --filter api docs:index",
    "docs:index:valkey": "pnpm --filter api docs:index:valkey",
    "docs:index:redis": "pnpm --filter api docs:index:redis",
    "docs:clean": "pnpm --filter api docs:clean",
    "test": "pnpm --filter api test",
    "test:watch": "pnpm --filter api test:watch",
    "test:cov": "pnpm --filter api test:cov",
    "test:integration": "pnpm --filter api test:integration",
    "test:integration:redis": "TEST_DB_PORT=6382 pnpm --filter api test:integration:redis",
    "test:integration:valkey": "TEST_DB_PORT=6380 pnpm --filter api test:integration:valkey",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "cli:build": "pnpm --filter @betterdb/monitor build",
    "cli:dev": "node packages/cli/bin/betterdb.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@fastify/middie": "9.1.0",
      "fastify": "^5.7.2",
      "glob": "10.5.0",
      "lodash": "4.17.23"
    }
  }
}